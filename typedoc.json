{
  "entryPoints": [
    "./src/client/index.ts",
    "./src/types/index.ts",
    "./src/server/index.ts",
    "./src/testing/index.ts",
    "./src/errors/index.ts"
  ],
  "out": "docs",
  "router": "group",
  "json": "docs/typedoc-output.json",
  "tsconfig": "tsconfig.json",
  "includeVersion": true,
  "readme": "README.md",
  "hideGenerator": true,
  "excludePrivate": true,
  "excludeExternals": true,
  "exclude": ["**/node_modules/**", "**/test/**", "**/examples/**", "**/e2e/**"],
  "categorizeByGroup": true,
  "theme": "default",
  "disableSources": true
}